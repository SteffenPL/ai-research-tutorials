{
  "formatVersion": "1.0.0",
  "title": "Codex CLI install & sign-in intro",
  "rounds": [
    {
      "id": "r-1",
      "kind": "terminal",
      "prompt": "curl -fsSL https://github.com/openai/codex/releases/latest/download/install.sh | sh",
      "steps": [
        {
          "id": "s-1",
          "included": true,
          "displayMode": "full",
          "inserted": {
            "type": "status",
            "text": "Codex CLI installed",
            "variant": "success",
            "comment": {
              "en": "The installer downloads the latest standalone Codex binary and places it on your PATH."
            }
          }
        }
      ]
    },
    {
      "id": "r-3",
      "kind": "terminal",
      "prompt": "codex login",
      "steps": [
        {
          "id": "s-3",
          "included": true,
          "displayMode": "full",
          "inserted": {
            "type": "status",
            "text": "Authenticated via browser sign-in",
            "variant": "success"
          }
        }
      ]
    },
    {
      "id": "r-4",
      "kind": "terminal",
      "prompt": "cd path/to/your/project && codex",
      "steps": [
        {
          "id": "s-4",
          "included": true,
          "displayMode": "full",
          "inserted": {
            "type": "output",
            "text": "Welcome to Codex!\nWorking directory: /path/to/your/project\n\nType a message to get started.",
            "comment": {
              "en": "Start Codex from the project folder you want it to inspect or edit."
            }
          }
        }
      ]
    }
  ]
}
